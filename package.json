{
  "name": "@grind-t/cbr-ratings",
  "version": "1.0.3",
  "homepage": "https://github.com/grind-t/cbr-ratings#readme",
  "bugs": {
    "url": "https://github.com/grind-t/cbr-ratings/issues"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grind-t/cbr-ratings.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "node --env-file=.env --experimental-transform-types --watch ./playground.ts",
    "fmt": "oxfmt",
    "lint": "oxlint --fix",
    "test:unit": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.unit.test.ts\"",
    "test:e2e": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.e2e.test.ts\"",
    "test": "node --experimental-transform-types --experimental-test-module-mocks --test \"src/**/*.test.ts\"",
    "build": "tsdown",
    "export:issuers": "node --env-file-if-exists=.env --experimental-transform-types ./scripts/export/issuers.ts",
    "export:bonds": "node --env-file-if-exists=.env --experimental-transform-types ./scripts/export/bonds.ts"
  },
  "dependencies": {
    "dayjs": "^1.11.18",
    "fetch-cookie": "^3.1.0"
  },
  "devDependencies": {
    "@grind-t/moex": "^1.0.8",
    "@grind-t/t-invest": "^1.0.0",
    "@grind-t/toolkit": "^2.1.0",
    "@types/node": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "tsdown": "latest",
    "typescript": "latest",
    "zod": "^4.0.5"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  }
}
